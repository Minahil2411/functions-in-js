<!DOCTYPE html>
<html>
    <head>
        <title>
            Functions
        </title>
    </head>
    <body>
        <h1>
            Functions in JS
        </h1>
        <p id="p3"></p>
        <p id="p4"></p>
        <script>
            function sum(a,b){
                return a+b
            }
            document.getElementById("p3").innerHTML=sum(45,78)
            document.getElementById("p4").innerHTML=sum(56,98)
        </script>
    </body>
</html>
